{
  "manifest_version": 3,
  "name": "Управление сетевыми запросами",
  "version": "1.0",
  "description": "Блокировка и подмена сетевых запросов",
  "permissions": [
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Управление запросами"
  }
}