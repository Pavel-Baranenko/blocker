{
  "manifest_version": 3,
  "name": "URL Blocker",
  "version": "1.0",
  "description": "Блокирует запросы по пользовательскому списку URL",
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Blocker"
  },
  
  "background": {
    "service_worker": "service-worker.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://*.google.com/*"],
      "js": ["content.js"]
    }
  ],
    
  "host_permissions": [
    "<all_urls>"
  ],
  
  "permissions": [
    "declarativeNetRequest",
    "storage"
  ]
}
